# GigShield Backend — Environment Configuration
PORT=5000
ML_SERVICE_URL=http://localhost:8000
OPENWEATHER_API_KEY=demo
NODE_ENV=development

# Notes:
# - Set OPENWEATHER_API_KEY to a real key from https://openweathermap.org/api
#   for live weather data. Leave as "demo" for simulated weather.
# - ML_SERVICE_URL points to the FastAPI ML service (default port 8000)
